# Copy this file to .env.local and fill in the real value before running
# the dev server or deploying.

# The ONLY place a domain should ever be hardcoded for this project —
# see Implementation Blueprint Section 7.3 and lib/constants.ts.
# Today (launch): your temporary Vercel subdomain, e.g.:
NEXT_PUBLIC_SITE_URL=https://your-project-name.vercel.app

# Later (after registering a custom domain): swap to, e.g.:
# NEXT_PUBLIC_SITE_URL=https://yourname.dev
# — then redeploy. No code changes required anywhere else.
